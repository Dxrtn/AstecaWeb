<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel - Portal Asteca</title>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
</head>
<body>
    <header class="header">
        <div class="header-container">
            <h1 class="logo"><i class="ph ph-buildings"></i> Asteca <span>Contabilidade</span></h1>
            <nav class="navbar">
                <span class="nav-link">Olá, Visitante</span>
                <a class="btn-primary" href="/login"><i class="ph ph-sign-in"></i> Fazer Login</a>
            </nav>
        </div>
    </header>

    <main class="dashboard-container">
        <div class="main-content">
            
            <section class="client-section">
                <h2 class="section-title"><i class="ph ph-user-circle"></i> Área do Cliente</h2>
                <div class="action-grid">
                    <a href="#" class="action-card">
                        <i class="ph ph-file-text"></i>
                        <span>Consultar Relatórios</span>
                    </a>
                    <a href="#" class="action-card">
                        <i class="ph ph-receipt"></i>
                        <span>Guias de Imposto</span>
                    </a>
                    <a href="#" class="action-card">
                        <i class="ph ph-users"></i>
                        <span>Folha de Pagamento</span>
                    </a>
                </div>
            </section>

            <section class="external-links-section">
                <h2 class="section-title"><i class="ph ph-link"></i> Links Externos e Consultas Rápidas</h2>
                <div class="action-grid">
                    <a href="#" class="action-card">
                        <i class="ph ph-identification-card"></i>
                        <span>Situação CNPJ</span>
                    </a>
                    <a href="#" class="action-card">
                        <i class="ph ph-invoice"></i>
                        <span>Emissão NFe</span>
                    </a>
                    <a href="#" class="action-card">
                        <i class="ph ph-bank"></i>
                        <span>Portal Gov.br</span>
                    </a>
                    <a href="#" class="action-card">
                        <i class="ph ph-certificate"></i>
                        <span>Certidões CRC/AL</span>
                    </a>
                </div>
            </section>
        </div>

        <aside class="sidebar">
            <h2 class="section-title"><i class="ph ph-info"></i> Resumo</h2>
            
            <div class="info-widget">
                <h4>Empresa Ativa</h4>
                <p>Nenhuma empresa logada.</p>
            </div>
            
            <div class="info-widget">
                <h4>Avisos da Contabilidade</h4>
                <p style="font-size: 0.9rem; color: var(--text-muted);">
                    Não se esqueça que o vencimento do Simples Nacional ocorre no dia 20 de cada mês.
                </p>
            </div>
            
            <hr style="border: 0; border-top: 1px solid var(--border-color); margin: 1.5rem 0;">
            
            <div class="info-widget">
                <h4>Precisa de ajuda?</h4>
                <p style="font-size: 0.9rem; margin-bottom: 1rem;">Nossa equipe de suporte está disponível.</p>
                <a href="#" class="btn-primary" style="display: block; text-align: center;">Falar no WhatsApp</a>
            </div>
        </aside>
    </main>

    <%- include('partials/footer') %>
</body>
</html>